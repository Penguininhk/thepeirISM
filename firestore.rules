/**
 * @file Firebase Security Rules for the School App.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based and ownership-based access control model.
 * Administrative actions are logged and secured. Announcements are segregated
 * into school-wide and class-specific collections for efficient querying and
 * authorization. User data is strictly controlled, and course selections are
 * private to the user.
 *
 * Data Structure:
 * - /actionLogs/{actionLogId}: Logs of administrative actions.
 * - /announcements/{announcementId}: School-wide announcements.
 * - /classes/{classId}: Class sections.
 * - /classes/{classId}/announcements/{announcementId}: Announcements specific to a class.
 * - /courses/{courseId}: Courses offered by the school.
 * - /courses/{courseId}/assignments/{assignmentId}: Assignments for a specific course.
 * - /assignments/{assignmentId}/submissions/{submissionId}: Student submissions for assignments.
 * - /users/{userId}: User profiles.
 * - /users/{userId}/courseSelections/{courseSelectionId}: Course selections made by students.
 *
 * Key Security Decisions:
 * - Admin roles are managed via custom claims (`isAdmin`).
 * - Listing users is disallowed to prevent unauthorized data scraping.
 * - Announcements leverage denormalized `classIds` and `schoolWide` flags for efficient authorization.
 * - Course selections are private to the user, stored under their profile.
 *
 * Denormalization for Authorization:
 * - Announcements have `classIds` and `schoolWide` to avoid needing to query classes during authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Logs of administrative actions, only accessible by admins.
     * @path /actionLogs/{actionLogId}
     * @allow (create) An admin user can create a new action log.
     * @deny (create) A non-admin user cannot create an action log.
     * @principle Restricts access to sensitive action logs to authorized admins only.
     */
    match /actionLogs/{actionLogId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description School-wide announcements, publicly readable, but only created/updated/deleted by admins.
     * @path /announcements/{announcementId}
     * @allow (get, list) Any user can read school-wide announcements.
     * @allow (create) An admin user can create a new school-wide announcement.
     * @deny (create) A non-admin user cannot create announcements.
     * @principle Allows public read access while restricting write access to admins.
     */
    match /announcements/{announcementId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Class sections; no specific security rules yet.
     * @path /classes/{classId}
     * @allow (get, list) Any user can read class data.
     * @allow (create) An admin user can create a new class.
     * @deny (create) A non-admin user cannot create a class.
     * @principle Allows public read access and restricts write access to admins for now.
     */
    match /classes/{classId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Announcements specific to a class. Teachers of the class can create, admins can manage. Students can view.
     * @path /classes/{classId}/announcements/{announcementId}
     * @allow (get, list) Any user can read class-specific announcements.
     * @allow (create) An admin user can create a class-specific announcement.
     * @deny (create) A non-admin user cannot create class-specific announcements.
     * @principle Allows public read access and restricts write access to admins for now.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Courses offered by the school. Only admins can create, others can read.
     * @path /courses/{courseId}
     * @allow (get, list) Any user can read course data.
     * @allow (create) An admin user can create a new course.
     * @deny (create) A non-admin user cannot create courses.
     * @principle Allows public read access and restricts write access to admins for now.
     */
    match /courses/{courseId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Assignments for a specific course. Teacher of the course and admins can manage. Others can read.
     * @path /courses/{courseId}/assignments/{assignmentId}
     * @allow (get, list) Any user can read assignments for a course.
     * @allow (create) An admin user can create a new assignment for a course.
     * @deny (create) A non-admin user cannot create assignments.
     * @principle Allows public read access and restricts write access to admins for now.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Student submissions for an assignment. Students can create/update their own submissions. Teachers and admins can read/update/delete.
     * @path /assignments/{assignmentId}/submissions/{submissionId}
     * @allow get: if isOwner(resource.data.studentId) || isAdmin();
     * @allow list: if isOwner(resource.data.studentId) || isAdmin();
     * @allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
     * @allow update: if (isOwner(resource.data.studentId) && resource != null) || (isAdmin() && resource != null);
     * @allow delete: if isExistingOwner(resource.data.studentId) || (isAdmin() && resource != null);
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get: if isOwner(resource.data.studentId) || isAdmin();
      allow list: if isOwner(resource.data.studentId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if (isOwner(resource.data.studentId) && resource != null) || (isAdmin() && resource != null);
      allow delete: if isExistingOwner(resource.data.studentId) || (isAdmin() && resource != null);
    }

    /**
     * @description User profiles. Users can read/update their own profiles. Admins can manage all profiles.
     * @path /users/{userId}
     * @allow get: if isOwner(userId) || isAdmin();
     * @allow list: if false;
     * @allow create: if isSignedIn() && isOwner(userId);
     * @allow update: if (isOwner(userId) && resource != null) || (isAdmin() && resource != null);
     * @allow delete: if isExistingOwner(userId) || (isAdmin() && resource != null);
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if (isOwner(userId) && resource != null) || (isAdmin() && resource != null);
      allow delete: if isExistingOwner(userId) || (isAdmin() && resource != null);
    }

    /**
     * @description Course selections made by a student. Only the student or an admin can access.
     * @path /users/{userId}/courseSelections/{courseSelectionId}
     * @allow get: if isOwner(userId) || isAdmin();
     * @allow list: if isOwner(userId) || isAdmin();
     * @allow create: if isSignedIn() && isOwner(userId) && request.resource.data.studentId == userId;
     * @allow update: if (isOwner(userId) && resource != null) || (isAdmin() && resource != null);
     * @allow delete: if isExistingOwner(userId) || (isAdmin() && resource != null);
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.studentId == userId;
      allow update: if (isOwner(userId) && resource != null) || (isAdmin() && resource != null);
      allow delete: if isExistingOwner(userId) || (isAdmin() && resource != null);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.isAdmin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}