/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for personal data and role-based access for shared resources.
 *
 * Data Structure:
 * - /actionLogs/{actionLogId}: Logs of administrative actions.
 * - /announcements/{announcementId}: School-wide announcements.
 * - /classes/{classId}: Class sections.
 * - /classes/{classId}/announcements/{announcementId}: Announcements specific to a class.
 * - /courses/{courseId}: Courses offered.
 * - /courses/{courseId}/assignments/{assignmentId}: Assignments for a course.
 * - /assignments/{assignmentId}/submissions/{submissionId}: Submissions for an assignment.
 * - /users/{userId}: User profiles.
 * - /users/{userId}/courseSelections/{courseSelectionId}: Course selections made by students.
 *
 * Key Security Decisions:
 * - Users can only read and write their own user documents (/users/{userId}).
 * - Course selections are user-owned (/users/{userId}/courseSelections/{courseSelectionId}).
 * - Announcements are publicly readable, but creating, updating, or deleting requires being the author. Class-specific announcements are publicly readable within the class context.
 * - Admin actions are logged in /actionLogs and are only writable by authenticated admins.
 * - Listing of user documents is disallowed.
 *
 * Denormalization for Authorization:
 * - Announcements include `classIds` and `schoolWide` flags to avoid requiring extra reads for determining visibility.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Logs of administrative actions, writeable only by authenticated admins.
     * @path /actionLogs/{actionLogId}
     * @allow create: if isSignedIn() && isAdmin(); Example: Admin creating an action log.
     * @allow get: if isSignedIn() && isAdmin(); Example: Admin reading a specific action log.
     * @allow list: if isSignedIn() && isAdmin(); Example: Admin listing all action logs.
     * @allow update: if false;
     * @allow delete: if false;
     * @deny create: if !isSignedIn() || !isAdmin(); Example: Non-admin user attempting to create an action log.
     * @deny get: if !isSignedIn() || !isAdmin(); Example: Non-admin user attempting to read an action log.
     * @deny list: if !isSignedIn() || !isAdmin(); Example: Non-admin user attempting to list action logs.
     * @principle Enforces admin-only access for logging administrative actions.
     */
    match /actionLogs/{actionLogId} {
      allow create: if isSignedIn() && isAdmin();
      allow get: if isSignedIn() && isAdmin();
      allow list: if isSignedIn() && isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description School-wide announcements. Publicly readable, only authors can modify.
     * @path /announcements/{announcementId}
     * @allow get: if true; Example: Any user reading an announcement.
     * @allow list: if true; Example: Any user listing announcements.
     * @allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid; Example: Author creating an announcement.
     * @allow update: if isSignedIn() && isExistingOwner(resource.data.authorId); Example: Author updating their own announcement.
     * @allow delete: if isSignedIn() && isExistingOwner(resource.data.authorId); Example: Author deleting their own announcement.
     * @deny create: if !isSignedIn() || request.resource.data.authorId != request.auth.uid; Example: User creating an announcement with mismatched author ID.
     * @deny update: if !isSignedIn() || !isExistingOwner(resource.data.authorId); Example: User updating an announcement they don't own.
     * @deny delete: if !isSignedIn() || !isExistingOwner(resource.data.authorId); Example: User deleting an announcement they don't own.
     * @principle Allows public reads but restricts writes to the announcement's author.
     */
    match /announcements/{announcementId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.authorId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.authorId);
    }

    /**
     * @description Represents a class section.
     * @path /classes/{classId}
     * @allow get: if true; Example: Any user reading a class.
     * @allow list: if true; Example: Any user listing classes.
     * @allow create: if isSignedIn(); Example: Authenticated user creating a class.
     * @allow update: if isSignedIn(); Example: Authenticated user updating a class.
     * @allow delete: if isSignedIn(); Example: Authenticated user deleting a class.
     * @principle Allows public reads and writes for prototyping purposes.
     */
    match /classes/{classId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Announcements specific to a class. Publicly readable, only authors can modify.
     * @path /classes/{classId}/announcements/{announcementId}
     * @allow get: if true; Example: Any user reading a class announcement.
     * @allow list: if true; Example: Any user listing class announcements.
     * @allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid; Example: Author creating a class announcement.
     * @allow update: if isSignedIn() && isExistingOwner(resource.data.authorId); Example: Author updating their own class announcement.
     * @allow delete: if isSignedIn() && isExistingOwner(resource.data.authorId); Example: Author deleting their own class announcement.
     * @deny create: if !isSignedIn() || request.resource.data.authorId != request.auth.uid; Example: User creating a class announcement with mismatched author ID.
     * @deny update: if !isSignedIn() || !isExistingOwner(resource.data.authorId); Example: User updating a class announcement they don't own.
     * @deny delete: if !isSignedIn() || !isExistingOwner(resource.data.authorId); Example: User deleting a class announcement they don't own.
     * @principle Allows public reads but restricts writes to the announcement's author.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.authorId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.authorId);
    }

    /**
     * @description Courses offered by the school.
     * @path /courses/{courseId}
     * @allow get: if true; Example: Any user reading a course.
     * @allow list: if true; Example: Any user listing courses.
     * @allow create: if isSignedIn(); Example: Authenticated user creating a course.
     * @allow update: if isSignedIn(); Example: Authenticated user updating a course.
     * @allow delete: if isSignedIn(); Example: Authenticated user deleting a course.
     * @principle Allows public reads and writes for prototyping purposes.
     */
    match /courses/{courseId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Assignments for a specific course.
     * @path /courses/{courseId}/assignments/{assignmentId}
     * @allow get: if true; Example: Any user reading a course assignment.
     * @allow list: if true; Example: Any user listing course assignments.
     * @allow create: if isSignedIn(); Example: Authenticated user creating a course assignment.
     * @allow update: if isSignedIn(); Example: Authenticated user updating a course assignment.
     * @allow delete: if isSignedIn(); Example: Authenticated user deleting a course assignment.
     * @principle Allows public reads and writes for prototyping purposes.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Student submissions for an assignment.
     * @path /assignments/{assignmentId}/submissions/{submissionId}
     * @allow get: if true; Example: Any user reading an assignment submission.
     * @allow list: if true; Example: Any user listing assignment submissions.
     * @allow create: if isSignedIn(); Example: Authenticated user creating an assignment submission.
     * @allow update: if isSignedIn(); Example: Authenticated user updating an assignment submission.
     * @allow delete: if isSignedIn(); Example: Authenticated user deleting an assignment submission.
     * @principle Allows public reads and writes for prototyping purposes.
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description User profiles. Only the user can read/write their own profile.
     * @path /users/{userId}
     * @allow get: if isOwner(userId); Example: User reading their own profile.
     * @allow list: if false; Example: Listing user profiles is not allowed.
     * @allow create: if isOwner(userId); Example: User creating their own profile.
     * @allow update: if isOwner(userId); Example: User updating their own profile.
     * @allow delete: if isExistingOwner(userId); Example: User deleting their own profile.
     * @deny get: if !isOwner(userId); Example: User attempting to read another user's profile.
     * @deny create: if !isOwner(userId); Example: User attempting to create a profile with a different ID.
     * @deny update: if !isOwner(userId); Example: User attempting to update another user's profile.
     * @deny delete: if !isExistingOwner(userId); Example: User attempting to delete another user's profile or a non-existent profile.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Course selections made by a student. Only the student can read/write their own selections.
     * @path /users/{userId}/courseSelections/{courseSelectionId}
     * @allow get: if isOwner(userId); Example: User reading their own course selections.
     * @allow list: if isOwner(userId); Example: User listing their own course selections.
     * @allow create: if isOwner(userId); Example: User creating a course selection for themselves.
     * @allow update: if isOwner(userId); Example: User updating their own course selection.
     * @allow delete: if isExistingOwner(userId); Example: User deleting their own course selection.
     * @deny get: if !isOwner(userId); Example: User attempting to read another user's course selections.
     * @deny list: if !isOwner(userId); Example: User attempting to list another user's course selections.
     * @deny create: if !isOwner(userId); Example: User attempting to create a course selection for another user.
     * @deny update: if !isOwner(userId); Example: User attempting to update another user's course selection.
     * @deny delete: if !isExistingOwner(userId); Example: User attempting to delete another user's course selection or a non-existent selection.
     * @principle Enforces document ownership for course selections.
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.isAdmin == true;
    }
  }
}