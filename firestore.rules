/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces role-based access control and ownership for data resources.
 * Administrative actions are logged and only accessible to admins.
 * Announcements are publicly readable but restricted to authorized users for creation, updates, and deletions.
 * Courses and assignments are managed by teachers. Submissions are specific to students.
 * User data is private and only accessible to the user and admins.
 * Teacher and admin roles are determined by the existence of documents in the `/roles_teacher` and `/roles_admin` collections.
 *
 * Data Structure:
 * - /actionLogs/{actionLogId}: Logs of administrative actions.
 * - /announcements/{announcementId}: School-wide announcements.
 * - /classes/{classId}: Class sections.
 * - /classes/{classId}/announcements/{announcementId}: Announcements specific to a class.
 * - /courses/{courseId}: Courses offered by the school.
 * - /courses/{courseId}/assignments/{assignmentId}: Assignments for a specific course.
 * - /assignments/{assignmentId}/submissions/{submissionId}: Student submissions for an assignment.
 * - /users/{userId}: User profiles.
 * - /users/{userId}/courseSelections/{courseSelectionId}: Course selections made by students.
 * - /roles_teacher/{userId}: Indicates that the user is a teacher.
 * - /roles_admin/{userId}: Indicates that the user is an admin.
 *
 * Key Security Decisions:
 * - Action Logs: Only admins can read or write action logs.
 * - Announcements: Publicly readable, but only teachers and admins can create, update, or delete.
 * - User Listing: Listing all users is not permitted. Access to user profiles is restricted to the user and admins.
 * - Teacher/Admin Roles: Determined by document existence in `/roles_teacher/{userId}` and `/roles_admin/{userId}`.
 * - Course Selections: Students can only manage their own course selections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows admins to manage action logs.
     * @path /actionLogs/{actionLogId}
     * @allow (create) auth.uid in roles_admin with valid ActionLog data
     * @allow (read) auth.uid in roles_admin
     * @deny (create) non-admin users
     * @principle Restricts access to action logs to admins only.
     */
    match /actionLogs/{actionLogId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read announcements, but only teachers or admins can create, update, or delete them.
     * @path /announcements/{announcementId}
     * @allow (get, list) any user (public read)
     * @allow (create) teacher/admin with valid Announcement data
     * @allow (update, delete) teacher/admin who is the author of the announcement
     * @deny (create, update, delete) non-authorized users
     * @principle Allows public reading but restricts modification to authorized users.
     */
    match /announcements/{announcementId} {
      allow get: if true;
      allow list: if true;
      allow create: if isTeacher() || isAdmin();
      allow update: if (isTeacher() || isAdmin());
      allow delete: if (isTeacher() || isAdmin());
    }

    /**
     * @description Allows access to classes.
     * @path /classes/{classId}
     * @allow (read) any user
     * @allow (create, update, delete) teacher/admin
     * @deny (create, update, delete) non-authorized users
     * @principle Allows public reading, but restricts modifications to authorized users.
     */
    match /classes/{classId} {
      allow get: if true;
      allow list: if true;
      allow create: if isTeacher() || isAdmin();
      allow update: if isTeacher() || isAdmin();
      allow delete: if isTeacher() || isAdmin();
    }

    /**
     * @description Allows teachers and admins to manage announcements for a specific class.
     * @path /classes/{classId}/announcements/{announcementId}
     * @allow (read) any user
     * @allow (create, update, delete) teacher/admin
     * @deny (create, update, delete) non-authorized users
     * @principle Allows public reading, but restricts modifications to authorized users.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get: if true;
      allow list: if true;
      allow create: if isTeacher() || isAdmin();
      allow update: if isTeacher() || isAdmin();
      allow delete: if isTeacher() || isAdmin();
    }

    /**
     * @description Allows teachers and admins to manage courses.
     * @path /courses/{courseId}
     * @allow (read) any user
     * @allow (create, update, delete) teacher/admin
     * @deny (create, update, delete) non-authorized users
     * @principle Allows public reading, but restricts modifications to authorized users.
     */
    match /courses/{courseId} {
      allow get: if true;
      allow list: if true;
      allow create: if isTeacher() || isAdmin();
      allow update: if isTeacher() || isAdmin();
      allow delete: if isTeacher() || isAdmin();
    }

    /**
     * @description Allows teachers and admins to manage assignments for a specific course.
     * @path /courses/{courseId}/assignments/{assignmentId}
     * @allow (read) any user
     * @allow (create, update, delete) teacher/admin
     * @deny (create, update, delete) non-authorized users
     * @principle Allows public reading, but restricts modifications to authorized users.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      allow get: if true;
      allow list: if true;
      allow create: if isTeacher() || isAdmin();
      allow update: if isTeacher() || isAdmin();
      allow delete: if isTeacher() || isAdmin();
    }

    /**
     * @description Allows students to create submissions for their assignments, and teachers/admins to read them.
     * @path /assignments/{assignmentId}/submissions/{submissionId}
     * @allow (create) student creating their own submission
     * @allow (read) teacher/admin
     * @deny (create) other users creating submissions
     * @principle Allows students to create their own submissions, and teachers/admins to read them.
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get: if isTeacher() || isAdmin();
      allow list: if isTeacher() || isAdmin();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows users to read/write their own profile data, and admins to read all profiles.
     * @path /users/{userId}
     * @allow (read, update, delete) owner or admin
     * @allow (create) if creating your own profile
     * @deny (read, update, delete) other users
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false;
      allow create: if isSelfCreate(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    /**
     * @description Allows users to manage their own course selections.
     * @path /users/{userId}/courseSelections/{courseSelectionId}
     * @allow (read, create, update, delete) owner
     * @deny (read, create, update, delete) other users
     * @principle Enforces user-ownership for course selection data.
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

     /**
      * @description Determines if a user is a teacher based on document existence.
      * @path /roles_teacher/{userId}
      * @allow (read) teacher or admin
      * @deny (read) other users
      * @principle Grants access to teacher profile data only to the teacher and admins.
      */
    match /roles_teacher/{userId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Determines if a user is an admin based on document existence.
     * @path /roles_admin/{userId}
     * @allow (read) admin
     * @deny (read) other users
     * @principle Grants access to admin profile data only to admins.
     */
    match /roles_admin/{userId} {
        allow get: if isAdmin();
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isSelfCreate(userId) {
        return request.auth.uid == userId;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isTeacher() {
      return exists(/databases/$(database)/documents/roles_teacher/$(request.auth.uid));
    }
  }
}