/**
 * @fileoverview Firestore Security Rules for the School App.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model, with specific rules
 * for teachers, students, and administrators. Data is segregated to ensure
 * users can only access information relevant to their role and courses.  The
 * rules prioritize authorization independence through denormalization.
 *
 * Data Structure:
 * - /announcements/{announcementId}: School-wide announcements.
 * - /classes/{classId}: Class details, including enrolled students.
 * - /classes/{classId}/announcements/{announcementId}: Class-specific announcements.
 * - /courses/{courseId}: Course information.
 * - /courses/{courseId}/assignments/{assignmentId}: Assignments for a specific course.
 * - /assignments/{assignmentId}/submissions/{submissionId}: Student submissions.
 * - /users/{userId}: User profiles.
 * - /users/{userId}/courseSelections/{courseSelectionId}: Student course selections.
 * - /roles_teacher/{userId}: Documents indicating a user is a teacher.
 * - /roles_admin/{userId}: Documents indicating a user is an administrator.
 *
 * Key Security Decisions:
 * - Teachers and admins are granted specific privileges based on document existence in their respective roles collections.
 * - Announcements include denormalized `classIds` and `schoolWide` flags for visibility checks.
 * - Submissions are stored under assignments and students for easy retrieval and validation.
 * - Course selections are stored under the user for ownership-based security.
 * - Listing users is forbidden.
 *
 * Denormalization for Authorization:
 * - Announcements include `classIds` and `schoolWide` for efficient access control.
 * - Classes include `studentIds` for quick student enrollment checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows reading school-wide announcements, and creating/updating/deleting only by admins.
     * @path /announcements/{announcementId}
     * @allow get, list: if true;
     * @allow create: if isAdmin();
     * @allow update: if isExistingAdmin();
     * @allow delete: if isExistingAdmin();
     * @deny create: if !isAdmin();
     * @deny update: if !isExistingAdmin();
     * @deny delete: if !isExistingAdmin();
     * @principle Public read, admin-only writes.
     */
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isExistingAdmin();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Allows reading class information.  No write access granted.
     * @path /classes/{classId}
     * @allow get, list: if true;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Public read-only access.
     */
    match /classes/{classId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows teachers and admins to create announcements for a class. Students can read announcements for their classes.
     * @path /classes/{classId}/announcements/{announcementId}
     * @allow get, list: if true;
     * @allow create: if isTeacher() || isAdmin();
     * @allow update: if isExistingTeacher() || isExistingAdmin();
     * @allow delete: if isExistingTeacher() || isExistingAdmin();
     * @deny create: if !(isTeacher() || isAdmin());
     * @deny update: if !(isExistingTeacher() || isExistingAdmin());
     * @deny delete: if !(isExistingTeacher() || isExistingAdmin());
     * @principle Teacher/Admin-only writes, public reads.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get, list: if true;
      allow create: if isTeacher() || isAdmin();
      allow update: if isExistingTeacher() || isExistingAdmin();
      allow delete: if isExistingTeacher() || isExistingAdmin();
    }

    /**
     * @description Allows reading course information. No write access granted.
     * @path /courses/{courseId}
     * @allow get, list: if true;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Public read-only access.
     */
    match /courses/{courseId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows teachers and admins to create assignments for their courses. Students can view assignments.
     * @path /courses/{courseId}/assignments/{assignmentId}
     * @allow get, list: if true;
     * @allow create: if isTeacher() || isAdmin();
     * @allow update: if isExistingTeacher() || isExistingAdmin();
     * @allow delete: if isExistingTeacher() || isExistingAdmin();
     * @deny create: if !(isTeacher() || isAdmin());
     * @deny update: if !(isExistingTeacher() || isExistingAdmin());
     * @deny delete: if !(isExistingTeacher() || isExistingAdmin());
     * @principle Teacher/Admin-only writes, public reads.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      allow get, list: if true;
      allow create: if isTeacher() || isAdmin();
      allow update: if isExistingTeacher() || isExistingAdmin();
      allow delete: if isExistingTeacher() || isExistingAdmin();
    }

    /**
     * @description Allows students to create submissions for their assignments. Teachers can read submissions for grading.
     * @path /assignments/{assignmentId}/submissions/{submissionId}
     * @allow get: if isTeacher() || isAdmin() || isOwner(resource.data.studentId);
     * @allow list: if isTeacher() || isAdmin();
     * @allow create: if isSignedIn();
     * @allow update: if isExistingTeacher() || isExistingAdmin();
     * @allow delete: if isExistingTeacher() || isExistingAdmin();
     * @deny create: if !isSignedIn();
     * @deny update: if !(isExistingTeacher() || isExistingAdmin());
     * @deny delete: if !(isExistingTeacher() || isExistingAdmin());
     * @principle Student-owned submissions, teacher grading.
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get: if isTeacher() || isAdmin() || isOwner(resource.data.studentId);
      allow list: if isTeacher() || isAdmin();
      allow create: if isSignedIn();
      allow update: if isExistingTeacher() || isExistingAdmin();
      allow delete: if isExistingTeacher() || isExistingAdmin();
    }

    /**
     * @description Allows users to read and update their own profile.
     * @path /users/{userId}
     * @allow get: if isOwner(userId);
     * @allow list: if false;
     * @allow create: if isOwner(userId);
     * @allow update: if isExistingOwner(userId);
     * @allow delete: if isExistingOwner(userId);
     * @deny create: if !isOwner(userId);
     * @deny update: if !isExistingOwner(userId);
     * @deny delete: if !isExistingOwner(userId);
     * @principle Owner-only access.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows students to manage their own course selections.
     * @path /users/{userId}/courseSelections/{courseSelectionId}
     * @allow get, list: if isOwner(userId);
     * @allow create: if isOwner(userId);
     * @allow update: if isExistingOwner(userId);
     * @allow delete: if isExistingOwner(userId);
     * @deny create: if !isOwner(userId);
     * @deny update: if !isExistingOwner(userId);
     * @deny delete: if !isExistingOwner(userId);
     * @principle Owner-only access.
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows admins to create teacher roles. Only admins can manage teacher roles.
     * @path /roles_teacher/{userId}
     * @allow get, list: if isAdmin();
     * @allow create: if isAdmin();
     * @allow update: if isExistingAdmin();
     * @allow delete: if isExistingAdmin();
     * @deny create: if !isAdmin();
     * @deny update: if !isExistingAdmin();
     * @deny delete: if !isExistingAdmin();
     * @principle Admin-only access.
     */
    match /roles_teacher/{userId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isExistingAdmin();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Allows admins to create admin roles. Only admins can manage admin roles.
     * @path /roles_admin/{userId}
     * @allow get, list: if isAdmin();
     * @allow create: if isAdmin();
     * @allow update: if isExistingAdmin();
     * @allow delete: if isExistingAdmin();
     * @deny create: if !isAdmin();
     * @deny update: if !isExistingAdmin();
     * @deny delete: if !isExistingAdmin();
     * @principle Admin-only access.
     */
    match /roles_admin/{userId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isExistingAdmin();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Prevents listing users, resolving the reported error.
     * @path /users
     * @deny list: if true;
     * @principle Explicitly deny listing of users.
     */
     match /users {
        allow get: if false;
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
     }


    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isExistingAdmin() {
        return isAdmin() && resource != null;
    }

    function isTeacher() {
      return exists(/databases/$(database)/documents/roles_teacher/$(request.auth.uid));
    }

    function isExistingTeacher() {
        return isTeacher() && resource != null;
    }
  }
}