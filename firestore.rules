/**
 * @description This ruleset enforces a role-based access control model.
 * All write operations are heavily restricted to admins or owners. Read operations are more permissive, with public reads for some collections.
 * @dataStructure
 * - /actionLogs/{actionLogId}: Logs of administrative actions.
 * - /announcements/{announcementId}: School-wide announcements.
 * - /classes/{classId}: Class section information.
 * - /classes/{classId}/announcements/{announcementId}: Announcements specific to a class.
 * - /courses/{courseId}: Courses offered by the school.
 * - /courses/{courseId}/assignments/{assignmentId}: Assignments for a specific course.
 * - /assignments/{assignmentId}/submissions/{submissionId}: Student submissions for an assignment.
 * - /users/{userId}: User profiles.
 * - /users/{userId}/courseSelections/{courseSelectionId}: Course selections made by students.
 * - /roles_teacher/{userId}: Documents indicating teacher role.
 * - /roles_admin/{userId}: Documents indicating admin role.
 * @keySecurityDecisions
 * - Action Logs are only readable to admins
 * - Listing of users is forbidden to prevent data leaks.
 * - `roles_teacher` and `roles_admin` collection documents can only be created by the user themselves. The document's existence confers elevated priviliges.
 * @denormalizationForAuthorization
 * - Announcements include `classIds` and a `schoolWide` flag to determine visibility without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Only admins can read and write action logs.
     * @path /actionLogs/{actionLogId}
     * @allow (get, list) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (create) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (update) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (delete) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @deny (get, list) if request.auth == null
     * @deny (create, update, delete) if request.auth == null
     * @principle Enforces admin-only access for action logs.
     */
    match /actionLogs/{actionLogId} {
      allow get: if isSignedIn() && isAdmin();
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Announcements are publicly readable, but only admins can create, update, or delete them.
     * @path /announcements/{announcementId}
     * @allow (get, list) if true;
     * @allow (create) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (update) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (delete) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @deny (create, update, delete) if request.auth == null
     * @principle Allows public read access while restricting write access to admins.
     */
    match /announcements/{announcementId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Classes are publicly readable but only admins can create, update and delete them
     * @path /classes/{classId}
     * @allow (get, list) if true;
     * @allow (create) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (update) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (delete) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @deny (create, update, delete) if request.auth == null
     * @principle Allows public read access while restricting write access to admins.
     */
    match /classes/{classId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Class-specific announcements can be read by anyone, but only admins can create them.
     * @path /classes/{classId}/announcements/{announcementId}
     * @allow (get, list) if true;
     * @allow (create) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (update) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (delete) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @deny (create, update, delete) if request.auth == null
     * @principle Allows public read access while restricting write access to admins.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Courses are publicly readable, but only admins can create, update or delete them.
     * @path /courses/{courseId}
     * @allow (get, list) if true;
     * @allow (create) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (update) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (delete) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @deny (create, update, delete) if request.auth == null
     * @principle Allows public read access while restricting write access to admins.
     */
    match /courses/{courseId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Assignments can be read by anyone, but only admins can create, update and delete them.
     * @path /courses/{courseId}/assignments/{assignmentId}
     * @allow (get, list) if true;
     * @allow (create) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (update) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (delete) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @deny (create, update, delete) if request.auth == null
     * @principle Allows public read access while restricting write access to admins.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Submissions can be read by anyone, but only admins can create, update and delete them.
     * @path /assignments/{assignmentId}/submissions/{submissionId}
     * @allow (get, list) if true;
     * @allow (create) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (update) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @allow (delete) if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     * @deny (create, update, delete) if request.auth == null
     * @principle Allows public read access while restricting write access to admins.
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin() && resource != null;
      allow delete: if isSignedIn() && isAdmin() && resource != null;
    }

    /**
     * @description Users can read and write their own profile data, and admins can do the same for any user. Listing is denied.
     * @path /users/{userId}
     * @allow (get) if isOwner(userId) || (isSignedIn() && isAdmin());
     * @allow (create) if isOwner(userId);
     * @allow (update) if isOwner(userId) && resource != null;
     * @allow (delete) if isOwner(userId) && resource != null;
     * @deny list
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || (isSignedIn() && isAdmin());
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Users can only read and write their own course selections.
     * @path /users/{userId}/courseSelections/{courseSelectionId}
     * @allow (get) if isOwner(userId);
     * @allow (list) if isOwner(userId);
     * @allow (create) if isOwner(userId);
     * @allow (update) if isOwner(userId) && resource != null;
     * @allow (delete) if isOwner(userId) && resource != null;
     * @principle Enforces user-ownership for course selections.
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description A user can create their own teacher role by creating the appropriate document. No one can read or delete this.
     * @path /roles_teacher/{userId}
     * @allow create: if isOwner(userId);
     * @deny get, list, update, delete
     * @principle User claims their own teacher role.
     */
    match /roles_teacher/{userId} {
      allow get: if false;
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description A user can create their own admin role by creating the appropriate document. No one can read or delete this.
     * @path /roles_admin/{userId}
     * @allow create: if isOwner(userId);
     * @deny get, list, update, delete
     * @principle User claims their own admin role.
     */
    match /roles_admin/{userId} {
      allow get: if false;
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
  }
}