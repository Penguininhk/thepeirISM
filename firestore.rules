rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description: Allows admins to manage action logs for auditing purposes.
     * @path: /actionLogs/{actionLogId}
     * @allow: (read, create, update, delete) if the user is an admin.
     * @deny: (read, create, update, delete) if the user is not an admin.
     * @principle: Restricts access to sensitive action logs to authorized personnel only.
     */
    match /actionLogs/{actionLogId} {
      // Admins can read action logs.
      allow get: if isAdmin();
      allow list: if isAdmin();

      // Only admins can create, update, or delete action logs.
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description: Allows anyone to read school-wide announcements, but only admins can manage them.
     * @path: /announcements/{announcementId}
     * @allow: (read) to anyone. (create, update, delete) if the user is an admin.
     * @deny: (create, update, delete) if the user is not an admin.
     * @principle: Provides public access to announcements while restricting management to authorized personnel.
     */
    match /announcements/{announcementId} {
      // Anyone can read announcements.
      allow get: if true;
      allow list: if true;

      // Only admins can create, update, or delete announcements.
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description: Allows anyone to read class information.
     * @path: /classes/{classId}
     * @allow: (read) to anyone.
     * @deny: (create, update, delete) to anyone.
     * @principle: Provides public read access to class details, but prevents unauthorized modifications.
     */
    match /classes/{classId} {
      // Anyone can read class information.
      allow get: if true;
      allow list: if true;

      // No one can create, update, or delete class information through the client.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description: Allows teachers and students within a class to access class-specific announcements, and teachers to manage them.
     * @path: /classes/{classId}/announcements/{announcementId}
     * @allow: (read) if the user is a teacher of the class or a student in the class. (create, update, delete) if the user is a teacher of the class.
     * @deny: (read, create, update, delete) if the user is not a teacher or student in the class.
     * @principle: Restricts announcement access and management to authorized class members only.
     */
    match /classes/{classId}/announcements/{announcementId} {
      let classIdVar = classId;
      // Teachers of the class or students in the class can read announcements.
      allow get: if isTeacherOfClass(classIdVar) || isStudentInClass(classIdVar);
      allow list: if isTeacherOfClass(classIdVar) || isStudentInClass(classIdVar);

      // Only teachers of the class can create, update, or delete announcements.
      allow create: if isTeacherOfClass(classIdVar);
      allow update: if isTeacherOfClass(classIdVar);
      allow delete: if isTeacherOfClass(classIdVar);
    }

    /**
     * @description: Allows anyone to read course information.
     * @path: /courses/{courseId}
     * @allow: (read) to anyone.
     * @deny: (create, update, delete) to anyone.
     * @principle: Provides public read access to course details, but prevents unauthorized modifications.
     */
    match /courses/{courseId} {
      // Anyone can read course information.
      allow get: if true;
      allow list: if true;

      // No one can create, update, or delete course information through the client.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description: Allows teachers to manage assignments for their courses.
     * @path: /courses/{courseId}/assignments/{assignmentId}
     * @allow: (read, create, update, delete) if the user is the teacher of the course.
     * @deny: (read, create, update, delete) if the user is not the teacher of the course.
     * @principle: Restricts assignment management to the course teacher only.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      let courseIdVar = courseId;
      // Teachers of the course can read assignments.
      allow get: if isTeacherOfCourse(courseIdVar);
      allow list: if isTeacherOfCourse(courseIdVar);

      // Only teachers of the course can create, update, or delete assignments.
      allow create: if isTeacherOfCourse(courseIdVar);
      allow update: if isTeacherOfCourse(courseIdVar);
      allow delete: if isTeacherOfCourse(courseIdVar);
    }

    /**
     * @description: Allows students to create submissions for their assignments, and teachers to grade and manage them.
     * @path: /assignments/{assignmentId}/submissions/{submissionId}
     * @allow: (create) if the user is a student submitting to their own assignment. (read, update, delete) if the user is the teacher for assignment.
     * @deny: (create, update, delete) if the user is not a student or a teacher.
     * @principle: Enables student submissions while restricting grading and management to the teacher.
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      let assignmentIdVar = assignmentId;
      // Students can create submissions for their own assignments.
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;

      // Teachers of the assignment can read submissions.
      allow get: if isTeacherOfAssignment(assignmentIdVar);
      allow list: if isTeacherOfAssignment(assignmentIdVar);

      // Only teachers of the assignment can update or delete submissions.
      allow update: if isTeacherOfAssignment(assignmentIdVar);
      allow delete: if isTeacherOfAssignment(assignmentIdVar);
    }

    /**
     * @description: Allows users to manage their own profiles, and admins to manage all profiles.
     * @path: /users/{userId}
     * @allow: (read, update, delete) if the user is the profile owner or an admin. (create) if the user is creating thier own profile.
     * @deny: (read, update, delete) if the user is not the profile owner or an admin.
     * @principle: Ensures users control their own profiles while allowing admin oversight.
     */
    match /users/{userId} {
      // Users can read their own profile, and admins can read any profile.
      allow get: if isOwner(userId) || isAdmin();

      // Prevent listing of users for privacy.
      allow list: if false;

      // Users can create their own profile.
      allow create: if isOwner(userId) && request.auth.uid == userId;

      // Users can update their own profile, and admins can update any profile.
      allow update: if isOwner(userId) || isAdmin();

      // Users can delete their own profile, and admins can delete any profile.
      allow delete: if isOwner(userId) || isAdmin();
    }

    /**
     * @description: Allows students to manage their own course selections, and admins to manage all course selections.
     * @path: /users/{userId}/courseSelections/{courseSelectionId}
     * @allow: (read, create, update, delete) if the user is the course selection owner or an admin.
     * @deny: (read, create, update, delete) if the user is not the course selection owner or an admin.
     * @principle: Ensures students control their course selections while allowing admin oversight.
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      // Users can read their own course selections, and admins can read any course selection.
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();

      // Users can create course selections for themselves.
      allow create: if isOwner(userId);

      // Users can update their own course selections, and admins can update any course selection.
      allow update: if isOwner(userId) || isAdmin();

      // Users can delete their own course selections, and admins can delete any course selection.
      allow delete: if isOwner(userId) || isAdmin();
    }

    /**
     * @description: Allows anyone to read teacher information. Only admins can create update and delete teacher documents.
     * @path: /roles_teacher/{userId}
     * @allow: (get) to anyone.
     * @deny: (create, update, delete) to anyone.
     * @principle: Restricts role management to administrators.
     */
    match /roles_teacher/{userId} {
        allow get: if true;
        allow list: if false; // Prevent listing of roles.
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
    }

    /**
     * @description: Allows anyone to read admin information. Only admins can create update and delete admin documents.
     * @path: /roles_admin/{userId}
     * @allow: (get) to anyone.
     * @deny: (create, update, delete) to anyone.
     * @principle: Restricts role management to administrators.
     */
    match /roles_admin/{userId} {
        allow get: if true;
        allow list: if false; // Prevent listing of roles.
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
    }

    // --- Helper Functions ---

    // Checks if the user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the user is the owner of the resource.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user is an administrator based on the existence of a document in the roles_admin collection.
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Checks if the user is a teacher based on the existence of a document in the roles_teacher collection.
    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_teacher/$(request.auth.uid));
    }

    // Checks if the user is a teacher of the given course.
    function isTeacherOfCourse(courseId) {
      return isTeacher() && exists(/databases/$(database)/documents/courses/$(courseId))
             && get(/databases/$(database)/documents/courses/$(courseId)).data.teacherId == request.auth.uid;
    }

    // Checks if the user is a teacher of the class.
    function isTeacherOfClass(classId) {
      return isTeacher() && exists(/databases/$(database)/documents/classes/$(classId))
             && get(/databases/$(database)/documents/classes/$(classId)).data.courseId != null
             && isTeacherOfCourse(get(/databases/$(database)/documents/classes/$(classId)).data.courseId);
    }

    // Checks if the user is a student in the class.
    function isStudentInClass(classId) {
        return isSignedIn() && exists(/databases/$(database)/documents/classes/$(classId)) && request.auth.uid in get(/databases/$(database)/documents/classes/$(classId)).data.studentIds;
    }

    // Checks if the user is a teacher of the assignment's course.
    function isTeacherOfAssignment(assignmentId) {
      return isTeacher() && exists(/databases/$(database)/documents/assignments/$(assignmentId)) && get(/databases/$(database)/documents/assignments/$(assignmentId)).data.courseId != null
             && isTeacherOfCourse(get(/databases/$(database)/documents/assignments/$(assignmentId)).data.courseId);
    }
  }
}