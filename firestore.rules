/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for personal data and role-based access for shared resources.
 *
 * Data Structure:
 * - /actionLogs/{actionLogId}: Logs of administrative actions.
 * - /announcements/{announcementId}: School-wide announcements.
 * - /classes/{classId}: Class sections.
 * - /classes/{classId}/announcements/{announcementId}: Announcements specific to a class.
 * - /courses/{courseId}: Courses offered.
 * - /courses/{courseId}/assignments/{assignmentId}: Assignments for a course.
 * - /assignments/{assignmentId}/submissions/{submissionId}: Submissions for an assignment.
 * - /users/{userId}: User profiles.
 * - /users/{userId}/courseSelections/{courseSelectionId}: Course selections made by a student.
 *
 * Key Security Decisions:
 * - Only authenticated users can access data.
 * - Users can only read and write their own user documents.
 * - Listing the /users collection is denied to prevent information disclosure.
 * - Announcements are publicly readable, but writes are restricted based on role.
 * - Submissions are only accessible to the student who created them and the teacher of the course.
 * - Admin access is controlled via custom claims.
 *
 * Denormalization for Authorization:
 * - Announcements include denormalized `classIds` and `schoolWide` flags to avoid requiring `get()` operations.
 *
 * Structural Segregation:
 * - Private user data is stored under /users/{userId} to ensure owner-only access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user ID matches the authenticated user's ID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user ID matches the authenticated user's ID and the resource exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the user has the 'admin' role.
     */
    function isAdmin() {
        return isSignedIn() && request.auth.token.isAdmin == true;
    }

    /**
     * @description Logs of administrative actions.
     * @path /actionLogs/{actionLogId}
     * @allow (create) Admin user can create an action log.
     * @deny (create) Non-admin user attempts to create an action log.
     * @allow (get) Admin user can get an action log.
     * @deny (get) Non-admin user attempts to get an action log.
     * @principle Restricts access to action logs to admins only.
     */
    match /actionLogs/{actionLogId} {
      allow get: if isAdmin();
      allow list: if false;
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description School-wide announcements.
     * @path /announcements/{announcementId}
     * @allow (get, list) Anyone can read school-wide announcements.
     * @allow (create) Teacher can create a school-wide announcement.
     * @deny (create) Non-teacher attempts to create an announcement.
     * @principle Public read, owner-only (teacher/admin) writes.
     */
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow create: if isSignedIn(); // TODO: add logic to check if user is teacher or admin.
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Represents a class section with denormalized studentIds to avoid complex queries.
     * @path /classes/{classId}
     */
    match /classes/{classId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Announcements specific to a class. Includes denormalized 'classIds' for authorization independence.
     * @path /classes/{classId}/announcements/{announcementId}
     * @allow (get, list) Anyone can read an announcement for a class.
     * @allow (create) Teacher can create an announcement for a class.
     * @deny (create) Non-teacher attempts to create a class announcement.
     * @principle Teacher/admin create, public read.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get,list: if true;
      allow create: if isSignedIn();  // TODO: add logic to check if user is teacher or admin and associated with the class.
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Courses offered by the school.
     * @path /courses/{courseId}
     */
    match /courses/{courseId} {
        allow get: if true;
        allow list: if true;
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
    }

    /**
     * @description Assignments for a specific course.
     * @path /courses/{courseId}/assignments/{assignmentId}
     */
    match /courses/{courseId}/assignments/{assignmentId} {
        allow get: if true;
        allow list: if true;
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
    }

    /**
     * @description Student submissions for an assignment.
     * @path /assignments/{assignmentId}/submissions/{submissionId}
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get: if true; // TODO: Allow only owner and course teacher to GET.
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description User profiles.
     * @path /users/{userId}
     * @allow (create) User can create their own profile.
     * @allow (get) User can read their own profile.
     * @deny (get) User attempts to read another user's profile.
     * @principle Owner-only access for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Listing users is not permitted.
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Course selections made by a student.
     * @path /users/{userId}/courseSelections/{courseSelectionId}
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}