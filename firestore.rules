/**
 * @file Overview
 * This ruleset enforces a role-based access control model with ownership constraints.
 * It leverages custom claims for admin roles and path-based ownership for user data.
 * Denormalization is used to optimize authorization checks, particularly for announcements and assignments.
 *
 * Data Structure:
 * - /actionLogs/{actionLogId}: Logs of admin actions.
 * - /announcements/{announcementId}: School-wide announcements.
 * - /classes/{classId}: Class information.
 * - /classes/{classId}/announcements/{announcementId}: Announcements specific to a class.
 * - /courses/{courseId}: Course information.
 * - /courses/{courseId}/assignments/{assignmentId}: Assignments for a course.
 * - /assignments/{assignmentId}/submissions/{submissionId}: Submissions for an assignment.
 * - /users/{userId}: User profiles.
 * - /users/{userId}/courseSelections/{courseSelectionId}: Course selections for a user.
 *
 * Key Security Decisions:
 * - Only admins can list action logs.
 * - Announcements are publicly readable, but creation, updates, and deletions are restricted.
 * - User listing is not allowed.
 * - The rules prioritize authorization independence, QAPs (Query Authorization Patterns) through denormalization, and structural segregation.
 *
 * Denormalization for Authorization:
 * - Announcements include `classIds` and `schoolWide` to determine visibility without extra reads.
 *
 * Structural Segregation:
 * - Course selections are stored under `/users/{userId}` to ensure only the user or an admin can manage them.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
        return request.auth.token.isAdmin == true;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Allows admins to manage action logs.
     * @path /actionLogs/{actionLogId}
     * @allow (list) User with `isAdmin: true` can list all action logs.
     * @deny (list) User without `isAdmin: true` cannot list action logs.
     * @principle Restricts access to action logs to administrators only.
     */
    match /actionLogs/{actionLogId} {
      allow get: if isSignedIn() && isAdmin();
      allow list: if isSignedIn() && isAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows public reading of announcements, but restricts creation, updates, and deletions.
     * @path /announcements/{announcementId}
     * @allow (get, list) Any user can read announcements.
     * @deny (create, update, delete) Only authorized users (e.g., admins) should be able to create, update, or delete announcements (TODO: Add admin role check in future).
     * @principle Allows public read access while restricting write access to authorized users.
     */
    match /announcements/{announcementId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows access to class information.
     * @path /classes/{classId}
     * @allow (get, list) Any user can read or list class data.
     * @deny (create, update, delete) Only authorized users (e.g., admins) should be able to create, update, or delete classes (TODO: Add admin role check in future).
     * @principle Allows public read access while restricting write access to authorized users.
     */
    match /classes/{classId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows management of announcements specific to a class.
     * @path /classes/{classId}/announcements/{announcementId}
     * @allow (get, list) Any user can read or list class announcements.
     * @deny (create, update, delete) Only authorized users (e.g., teachers) can create, update, or delete announcements (TODO: Add teacher role check in future).
     * @principle Allows public read access while restricting write access to authorized users.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows access to course information.
     * @path /courses/{courseId}
     * @allow (get, list) Any user can read course data.
     * @deny (create, update, delete) Only authorized users (e.g., admins) can create, update, or delete courses (TODO: Add admin role check in future).
     * @principle Allows public read access while restricting write access to authorized users.
     */
    match /courses/{courseId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows management of assignments for a specific course.
     * @path /courses/{courseId}/assignments/{assignmentId}
     * @allow (get, list) Any user can read assignments for a specific course.
     * @deny (create, update, delete) Only authorized users (e.g., teachers) can create, update, or delete assignments (TODO: Add teacher role check in future).
     * @principle Allows public read access while restricting write access to authorized users.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows management of student submissions for an assignment.
     * @path /assignments/{assignmentId}/submissions/{submissionId}
     * @allow (get) Any user can get a submission.
     * @allow (list) Any user can list submissions.
     * @deny (create, update, delete) Only the student who owns the submission or an admin can modify it (TODO: Add submission ownership check and admin role check).
     * @principle Restricts access to submissions to the owner and admins.
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows access to user profiles. User listing is denied.
     * @path /users/{userId}
     * @allow (create) User can create their own profile if the userId matches their auth.
     * @allow (get, update, delete) User can only access their own profile.
     * @deny (list) User listing is not allowed.
     * @deny (create) User cannot create a profile with a mismatched userId.
     * @deny (update, delete) User cannot update/delete someone else's profile.
     * @principle Enforces user ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows management of course selections made by a student.
     * @path /users/{userId}/courseSelections/{courseSelectionId}
     * @allow (get, list, create, update, delete) Only the user who owns the course selections can manage them.
     * @deny (get, list, create, update, delete) Users cannot manage course selections for other users.
     * @principle Enforces user ownership for course selection data.
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}