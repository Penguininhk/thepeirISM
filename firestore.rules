/**
 * @fileoverview Firestore Security Rules for the School App.
 *
 * Core Philosophy:
 * This ruleset enforces a hybrid security model, balancing public readability with owner-only or role-based write access.
 *
 * Data Structure:
 * - `/actionLogs/{actionLogId}`: Stores logs of administrative actions.
 * - `/announcements/{announcementId}`: School-wide announcements.
 * - `/classes/{classId}`: Class sections.
 * - `/classes/{classId}/announcements/{announcementId}`: Announcements specific to a class.
 * - `/courses/{courseId}`: Courses offered by the school.
 * - `/courses/{courseId}/assignments/{assignmentId}`: Assignments for a specific course.
 * - `/assignments/{assignmentId}/submissions/{submissionId}`: Student submissions for an assignment.
 * - `/users/{userId}`: User profiles.
 * - `/users/{userId}/courseSelections/{courseSelectionId}`: Course selections made by students.
 *
 * Key Security Decisions:
 * - Listing of users is denied.
 * - Admin roles are checked using the `isAdmin` custom claim on the user's auth token.
 * - Announcements include denormalized `classIds` and `schoolWide` flags to avoid needing `get()` operations to determine visibility.
 * - Submissions are stored under a path that includes both `assignmentId` and `studentId` for easy retrieval and permission validation.
 * - Access to course selections uses path-based ownership (`/users/{userId}/courseSelections/{courseSelectionId}`).
 *
 * Denormalization for Authorization:
 * - Announcements denormalize `classIds` and `schoolWide` to optimize announcement visibility checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows admins to manage action logs for auditing purposes.
     * @path /actionLogs/{actionLogId}
     * @allow (create, update, delete) User with `isAdmin` claim.
     * @deny (create, update, delete) Non-admin user.
     * @principle Role-based access control for administrative actions.
     */
    match /actionLogs/{actionLogId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.token.isAdmin == true;
    }

    /**
     * @description Allows anyone to read announcements. Only admins can manage announcements.
     * @path /announcements/{announcementId}
     * @allow (get, list) Any signed-in user.
     * @allow (create, update, delete) User with `isAdmin` claim.
     * @deny (create, update, delete) Non-admin user.
     * @principle Public read access with role-based write access.
     */
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn() && request.auth.token.isAdmin == true;
    }

    /**
     * @description Allows admins to manage classes.
     * @path /classes/{classId}
     * @allow (get, list) Any signed-in user.
     * @allow (create, update, delete) User with `isAdmin` claim.
     * @deny (create, update, delete) Non-admin user.
     * @principle Role-based access control for class management.
     */
    match /classes/{classId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.token.isAdmin == true;
    }

    /**
     * @description Allows teachers and admins to manage announcements within classes, and students to read them.
     * @path /classes/{classId}/announcements/{announcementId}
     * @allow (get, list) Any signed-in user.
     * @allow (create) Teacher or Admin creating an announcement for their class.
     * @allow (update, delete) Admin updating or deleting an announcement.
     * @deny (create, update, delete) Non-admin user.
     * @principle Shared access for announcements within a class.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.token.isAdmin == true; // TODO: Add teacher validation if needed
      allow update, delete: if isSignedIn() && request.auth.token.isAdmin == true;
    }

    /**
     * @description Allows admins to manage courses.
     * @path /courses/{courseId}
     * @allow (get, list) Any signed-in user.
     * @allow (create, update, delete) User with `isAdmin` claim.
     * @deny (create, update, delete) Non-admin user.
     * @principle Role-based access control for course management.
     */
    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.token.isAdmin == true;
    }

    /**
     * @description Allows teachers and admins to manage assignments within a course.
     * @path /courses/{courseId}/assignments/{assignmentId}
     * @allow (get, list) Any signed-in user.
     * @allow (create, update, delete) User with `isAdmin` claim. // TODO: Add teacher validation if needed
     * @deny (create, update, delete) Non-admin user.
     * @principle Shared access for assignments within a course.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.token.isAdmin == true; // TODO: Add teacher validation if needed
    }

    /**
     * @description Allows students to create submissions for their assignments.  Allows admins to read and update submissions.
     * @path /assignments/{assignmentId}/submissions/{submissionId}
     * @allow (get, list) Any signed-in user.
     * @allow (create) Student creating a submission for their assignment.
     * @allow (update, delete) Admin updating or deleting the submission.
     * @deny (create) Non-student user.
     * @principle Shared access for submissions within an assignment.
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn(); // TODO: Add student validation to only allow students to create submissions.
      allow update, delete: if isSignedIn() && request.auth.token.isAdmin == true;
    }

    /**
     * @description Allows a user to read and write their own profile.  Admins can manage all user profiles.
     * @path /users/{userId}
     * @allow (get) Any signed-in user.
     * @allow (create) User creating their own profile.
     * @allow (update, delete) User updating their own profile or Admin updating any profile.
     * @deny (list) Listing all users is prohibited.
     * @principle Owner-only access to profile with admin override.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // Prevent listing of all users.
      allow create: if isSignedIn() && isOwner(userId);
      allow update, delete: if isSignedIn() && (isOwner(userId) || request.auth.token.isAdmin == true) && resource != null;
    }

    /**
     * @description Allows a user to manage their own course selections. Admins have no access to this collection.
     * @path /users/{userId}/courseSelections/{courseSelectionId}
     * @allow (get, list) User reading their own course selections.
     * @allow (create, update, delete) User managing their own course selections.
     * @deny (create, update, delete) Non-owner user.
     * @principle Owner-only access to course selections.
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get, list: if isSignedIn() && isOwner(userId);
      allow create, update, delete: if isSignedIn() && isOwner(userId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
  }
}