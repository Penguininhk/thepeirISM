/**
 * @fileoverview Firestore Security Rules.
 *
 * Core Philosophy: This ruleset implements a role-based access control model with ownership constraints.
 * Teachers and admins are identified by the existence of documents in `/roles_teacher/{userId}` and `/roles_admin/{userId}` respectively.
 * Data access is generally restricted to the owner (user) or elevated roles (teacher, admin).
 *
 * Data Structure: The Firestore database is organized hierarchically with collections for users, courses, classes, assignments, and announcements.
 * User-specific data (e.g., course selections) is nested under `/users/{userId}`.
 * Announcements are stored in a top-level collection for school-wide visibility and under class-specific collections for targeted announcements.
 *
 * Key Security Decisions:
 * - Listing all users is explicitly denied to prevent information disclosure.
 * - Teacher and admin roles are determined by document existence in dedicated collections, eliminating the need for custom claims.
 * - Public read access is granted for certain collections (e.g., announcements) to facilitate broad information dissemination.
 *
 * Denormalization for Authorization:
 * - Class documents denormalize studentIds to simplify authorization checks for class-specific announcements and assignments.
 * - Announcement documents include `classIds` and `schoolWide` flags to avoid costly `get()` operations when determining visibility.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Logs of administrative actions. Only admins can create, update, or delete action logs.
     * @path /actionLogs/{actionLogId}
     * @allow (create) An admin user creates a new action log.
     *   - Auth: `request.auth.uid` is an admin.
     *   - Data: `request.resource.data.adminId` is the ID of the admin.
     * @allow (get, list) Any authenticated user can read action logs (for auditing purposes).
     * @deny (update, delete) Non-admin user attempts to update or delete an action log.
     *   - Auth: `request.auth.uid` is not an admin.
     * @principle Restricts modification of action logs to administrative users only.
     */
    match /actionLogs/{actionLogId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin(request.auth.uid);
      allow update, delete: if false;
    }

    /**
     * @description School-wide announcements. Anyone can read announcements, but only admins can create, update, or delete them.
     * @path /announcements/{announcementId}
     * @allow (get, list) Any user, signed in or not, can read the announcements.
     * @allow (create) An admin user creates a new announcement.
     *   - Auth: `request.auth.uid` is an admin.
     * @deny (update, delete) Non-admin user attempts to update or delete an announcement.
     *   - Auth: `request.auth.uid` is not an admin.
     * @principle Provides public read access to announcements while restricting write access to admins.
     */
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow create: if isAdmin(request.auth.uid);
      allow update, delete: if false;
    }

    /**
     * @description Represents a class section. Anyone can read class details, but only admins can create, update, or delete them.
     * @path /classes/{classId}
     * @allow (get, list) Any user, signed in or not, can read the class details.
     * @allow (create) An admin user creates a new class.
     *   - Auth: `request.auth.uid` is an admin.
     * @deny (update, delete) Non-admin user attempts to update or delete a class.
     *   - Auth: `request.auth.uid` is not an admin.
     * @principle Public read, admin-only write access for class information.
     */
    match /classes/{classId} {
      allow get, list: if true;
      allow create: if isAdmin(request.auth.uid);
      allow update, delete: if false;
    }

    /**
     * @description Announcements specific to a class. Only teachers or admins can create class announcements, and only enrolled students, teachers, or admins can read them.
     * @path /classes/{classId}/announcements/{announcementId}
     * @allow (get, list) A student enrolled in the class, the teacher of the class, or an admin reads a class announcement.
     *   - Auth: `request.auth.uid` is a student or teacher of the class, or an admin.
     * @allow (create) The teacher of the class or an admin creates a new class announcement.
     *   - Auth: `request.auth.uid` is the teacher of the class or an admin.
     * @deny (update, delete) Non-teacher/admin attempts to update or delete a class announcement.
     *   - Auth: `request.auth.uid` is not the teacher of the class or an admin.
     * @principle Restricts class announcement creation to teachers/admins and read access to enrolled students/teachers/admins.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin(request.auth.uid) || isTeacher(request.auth.uid);
      allow update, delete: if false;
    }

    /**
     * @description Courses offered by the school. Anyone can read course details, but only admins can create, update, or delete them.
     * @path /courses/{courseId}
     * @allow (get, list) Any user can read the course details.
     * @allow (create) An admin user creates a new course.
     *   - Auth: `request.auth.uid` is an admin.
     * @deny (update, delete) Non-admin user attempts to update or delete a course.
     *   - Auth: `request.auth.uid` is not an admin.
     * @principle Public read access to course information, restricted write access to admins.
     */
    match /courses/{courseId} {
      allow get, list: if true;
      allow create: if isAdmin(request.auth.uid);
      allow update, delete: if false;
    }

    /**
     * @description Assignments for a specific course. Only teachers/admins can create assignments, and only enrolled students, teachers, or admins can read them.
     * @path /courses/{courseId}/assignments/{assignmentId}
     * @allow (get, list) A student enrolled in the course, the teacher of the course, or an admin reads an assignment.
     *   - Auth: `request.auth.uid` is a student or teacher of the course, or an admin.
     * @allow (create) The teacher of the course or an admin creates a new assignment.
     *   - Auth: `request.auth.uid` is the teacher of the course or an admin.
     * @deny (update, delete) Non-teacher attempts to update or delete an assignment.
     *   - Auth: `request.auth.uid` is not the teacher of the course or an admin.
     * @principle Restricts assignment creation to teachers/admins and read access to enrolled students/teachers/admins.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin(request.auth.uid) || isTeacher(request.auth.uid);
      allow update, delete: if false;
    }

    /**
     * @description Student submissions for an assignment. Students can create submissions for their assignments. Teachers and admins can read and update submissions for grading/feedback.
     * @path /assignments/{assignmentId}/submissions/{submissionId}
     * @allow (get, list) A teacher, the student who owns the submission, or an admin reads a submission.
     *   - Auth: `request.auth.uid` is the teacher, the student, or an admin.
     * @allow (create) A student creates a submission for an assignment.
     *   - Auth: `request.auth.uid` is a student.
     * @deny (update, delete) Only teacher and admins can update submissions
     *   - Auth: `request.auth.uid` is not the teacher or an admin.
     * @principle Students can submit assignments, and teachers can view and grade them.
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description User profiles. Users can only read/write their own profile data.
     * @path /users/{userId}
     * @allow (get) Any signed-in user can read a profile.
     * @allow (create) A user can create their own profile if the userId matches their auth.
     *   - Auth: `request.auth.uid` matches the `userId`.
     * @deny (update, delete) A user can not update or delete a profile.
     *   - Auth: `request.auth.uid` does not match the `userId`.
     * @principle Enforces strict user ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId);
      allow update, delete: if false;
    }

    /**
     * @description Course selections made by a student. Only the student (or an admin) can view or modify their course selections.
     * @path /users/{userId}/courseSelections/{courseSelectionId}
     * @allow (get, list) The user or an admin can read their course selections.
     *   - Auth: `request.auth.uid` matches the `userId` or the user is an admin.
     * @allow (create) A user can create their own course selection under their profile.
     *   - Auth: `request.auth.uid` matches the `userId`.
     * @deny (update, delete) A user or non-admin cannot update or delete another user's course selection.
     *   - Auth: `request.auth.uid` does not match the `userId` and the user is not an admin.
     * @principle Restricts course selection access to the owner (student) or an admin.
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if false;
    }

    /**
     * @description Documents indicating a user is a teacher. Existence implies the teacher role. Admins can create, others cannot.
     * @path /roles_teacher/{userId}
     * @allow (get, list) Teacher user can get their record, but no listing.
     * @allow (create) Admins can create teacher role assignments.
     *   - Auth: `request.auth.uid` is an admin.
     * @deny (update, delete) Only admins can manage teacher roles.
     * @principle Restricts teacher role assignment to admins.
     */
    match /roles_teacher/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isAdmin(request.auth.uid);
      allow update, delete: if false;
    }

    /**
     * @description Documents indicating a user is an administrator. Existence implies the admin role.
     * @path /roles_admin/{userId}
     * @allow (get, list) Admin user can get their record, but no listing.
     * @allow (create) Only admins can assign the admin role.
     *   - Auth: `request.auth.uid` is an admin.
     * @deny (update, delete) Non-admins can't modify the admin role.
     * @principle Restricts admin role assignment to existing admins.
     */
    match /roles_admin/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isAdmin(request.auth.uid);
      allow update, delete: if false;
    }

    // Prevent listing of all users
    match /users {
        allow list: if false;
    }

    // --- Helper Functions ---

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the document.
     * @param {string} userId - The user ID to check against.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is an admin by verifying the existence of their admin role document.
     * @param {string} userId - The user ID to check.
     * @return {boolean} True if the user is an admin, false otherwise.
     */
    function isAdmin(userId) {
        return exists(/databases/$(database)/documents/roles_admin/$(userId));
    }

    /**
     * @description Checks if the user is a teacher by verifying the existence of their teacher role document.
     * @param {string} userId - The user ID to check.
     * @return {boolean} True if the user is a teacher, false otherwise.
     */
    function isTeacher(userId) {
        return exists(/databases/$(database)/documents/roles_teacher/$(userId));
    }
  }
}