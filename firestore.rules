/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based and ownership-based access control model.
 * Administrative actions are logged. Teachers manage courses and assignments.
 * Students submit assignments and manage course selections.
 *
 * Data Structure:
 * - /actionLogs/{actionLogId}: Logs of administrative actions.
 * - /announcements/{announcementId}: School-wide announcements.
 * - /classes/{classId}: Class sections with denormalized student IDs.
 * - /classes/{classId}/announcements/{announcementId}: Class-specific announcements.
 * - /courses/{courseId}: Courses offered by the school.
 * - /courses/{courseId}/assignments/{assignmentId}: Assignments for a course.
 * - /assignments/{assignmentId}/submissions/{submissionId}: Submissions for assignments.
 * - /users/{userId}: User profiles.
 * - /users/{userId}/courseSelections/{courseSelectionId}: Course selections.
 * - /roles_teacher/{userId}: Indicates a user is a teacher.
 * - /roles_admin/{userId}: Indicates a user is an admin.
 *
 * Key Security Decisions:
 * - User listing is denied to prevent unauthorized access to user data.
 * - Role-based access uses document existence checks in /roles_teacher/{userId} and /roles_admin/{userId}.
 * - Data is denormalized to improve security rule performance and avoid costly `get()` calls.
 * - Drafts or non-public data are stored in user-specific subcollections to avoid the need for complex filtering based on boolean flags.
 *
 * Denormalization for Authorization:
 * - Announcements include denormalized `classIds` and a `schoolWide` flag.
 * - Classes include a denormalized list of `studentIds`.
 *
 * Structural Segregation:
 * - Teacher and admin roles are implemented using separate collection to enable simple existence checks.
 *   This eliminates the need to read user documents to determine roles.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Logs of administrative actions. Only admins can create action logs.
     * @path /actionLogs/{actionLogId}
     * @allow (create) If the user is an admin. The adminId must match the user ID.
     * @deny (create) If the user is not an admin.
     * @deny (get, list, update, delete) Always deny.
     * @principle Only admins can create action logs for auditing purposes.
     */
    match /actionLogs/{actionLogId} {
      allow get, list, update, delete: if false;
      allow create: if isAdmin(request.auth.uid) && request.resource.data.adminId == request.auth.uid;
    }

    /**
     * @description School-wide announcements. Anyone can read announcements. Only teachers can create.
     * @path /announcements/{announcementId}
     * @allow (get, list) Anyone can read the announcements.
     * @allow (create) Teachers can create announcements. The authorId must match the user ID.
     * @allow (update, delete) Only the author can update/delete.
     * @deny (create, update, delete) If the user is not a teacher or the author.
     * @principle Public read, owner-only writes for announcements.
     */
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow create: if isTeacher(request.auth.uid) && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isExistingOwner(request.auth.uid, resource.data.authorId);
    }

    /**
     * @description Class sections with denormalized studentIds.
     * @path /classes/{classId}
     * @allow (get) Any signed-in user can read class information.
     * @allow (list) Teachers can list the classes.
     * @allow (create) Only admins can create classes.
     * @allow (update, delete) Only admins can update/delete classes.
     * @deny (get, list, create, update, delete) If conditions are not met.
     * @principle Admins manage classes. Teachers can view class lists.
     */
    match /classes/{classId} {
      allow get: if isSignedIn();
      allow list: if isTeacher(request.auth.uid);
      allow create: if isAdmin(request.auth.uid);
      allow update, delete: if isAdmin(request.auth.uid);
    }

    /**
     * @description Announcements specific to a class.
     * @path /classes/{classId}/announcements/{announcementId}
     * @allow (get, list) Students or teachers in the class can view announcements.
     * @allow (create) Teachers in the class can create announcements. authorId must match the user ID.
     * @allow (update, delete) Only the author can update/delete.
     * @deny (get, list, create, update, delete) If conditions are not met.
     * @principle Class-specific announcements managed by teachers, visible to students.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get, list: if getClass(classId).data.studentIds.hasAny([request.auth.uid]) || isTeacherOfClass(request.auth.uid, classId);
      allow create: if isTeacherOfClass(request.auth.uid, classId) && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isExistingOwner(request.auth.uid, resource.data.authorId);
    }

    /**
     * @description Courses offered by the school.
     * @path /courses/{courseId}
     * @allow (get, list) Any signed-in user can read course information.
     * @allow (create) Only admins can create courses. teacherId must exist in request.
     * @allow (update, delete) Only admins can update/delete courses.
     * @deny (get, list, create, update, delete) If conditions are not met.
     * @principle Admins manage courses, visible to all users.
     */
    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin(request.auth.uid);
      allow update, delete: if isAdmin(request.auth.uid);
    }

    /**
     * @description Assignments for a specific course.
     * @path /courses/{courseId}/assignments/{assignmentId}
     * @allow (get, list) Any signed-in user can view assignments for a course.
     * @allow (create) Teachers of the course can create assignments.
     * @allow (update, delete) Teachers of the course can update/delete assignments.
     * @deny (get, list, create, update, delete) If conditions are not met.
     * @principle Teachers manage assignments within their courses.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      allow get, list: if isSignedIn();
      allow create: if isTeacherOfCourse(request.auth.uid, courseId);
      allow update, delete: if isTeacherOfCourse(request.auth.uid, courseId);
    }

    /**
     * @description Student submissions for an assignment.
     * @path /assignments/{assignmentId}/submissions/{submissionId}
     * @allow (get) The student who made the submission or the teacher of the course can view the submission.
     * @allow (list) The student who made the submission or the teacher of the course can list submissions.
     * @allow (create) Students can create submissions for their assignments.  studentId must match user ID.
     * @allow (update, delete) The student who made the submission or the teacher can update/delete.
     * @deny (get, list, create, update, delete) If conditions are not met.
     * @principle Students submit assignments, teachers can grade.
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get, list: if request.auth.uid == resource.data.studentId || isTeacherOfAssignment(request.auth.uid, assignmentId);
      allow create: if request.resource.data.studentId == request.auth.uid && isStudentOfAssignment(request.auth.uid, assignmentId);
      allow update, delete: if (request.auth.uid == resource.data.studentId && isStudentOfAssignment(request.auth.uid, assignmentId)) || isTeacherOfAssignment(request.auth.uid, assignmentId);
    }

    /**
     * @description User profiles.
     * @path /users/{userId}
     * @allow (get) Any signed-in user can read a user profile.
     * @allow (create) Users can create their own profile. The userId must match the request.
     * @allow (update, delete) Users can update/delete their own profile.
     * @deny (list) Listing users is not allowed.
     * @deny (get, create, update, delete) If conditions are not met.
     * @principle Users own their profiles.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update, delete: if isExistingOwner(userId, userId);
    }

    /**
     * @description Course selections made by a student.
     * @path /users/{userId}/courseSelections/{courseSelectionId}
     * @allow (get, list) The student can view their own course selections.
     * @allow (create) The student can create course selections.  studentId must match the user ID.
     * @allow (update, delete) The student can update/delete their course selections.
     * @deny (get, list, create, update, delete) If conditions are not met.
     * @principle Students manage their course selections.
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.studentId == userId;
      allow update, delete: if isExistingOwner(userId, userId) && resource.data.studentId == userId;
    }

    /**
     * @description Documents indicating a user is a teacher.
     * @path /roles_teacher/{userId}
     * @allow (get, list) Always deny.
     * @allow (create) Only admins can create teacher roles.
     * @allow (update, delete) Only admins can update/delete teacher roles.
     * @deny (get, list, create, update, delete) If conditions are not met.
     * @principle Admins manage teacher roles.
     */
    match /roles_teacher/{userId} {
      allow get, list: if false;
      allow create: if isAdmin(request.auth.uid);
      allow update, delete: if isAdmin(request.auth.uid);
    }

    /**
     * @description Documents indicating a user is an administrator.
     * @path /roles_admin/{userId}
     * @allow (get, list) Always deny.
     * @allow (create) Only admins can create admin roles.
     * @allow (update, delete) Only admins can update/delete admin roles.
     * @deny (get, list, create, update, delete) If conditions are not met.
     * @principle Admins manage administrator roles.
     */
    match /roles_admin/{userId} {
      allow get, list: if false;
      allow create: if isAdmin(request.auth.uid);
      allow update, delete: if isAdmin(request.auth.uid);
    }

    //------------------ Helper Functions --------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId, ownerId) {
      return isOwner(userId) && resource != null && ownerId == userId;
    }

    function isAdmin(userId) {
      return exists(/databases/$(database)/documents/roles_admin/$(userId));
    }

    function isTeacher(userId) {
      return exists(/databases/$(database)/documents/roles_teacher/$(userId));
    }

    function getClass(classId) {
      return get(/databases/$(database)/documents/classes/$(classId));
    }

    function getCourse(courseId) {
      return get(/databases/$(database)/documents/courses/$(courseId));
    }

    function getAssignment(assignmentId) {
      return get(/databases/$(database)/documents/courses/$(assignmentId));
    }

    function isTeacherOfClass(userId, classId) {
      return isTeacher(userId) && getClass(classId).data.teacherId == userId;
    }

    function isTeacherOfCourse(userId, courseId) {
        return isTeacher(userId) && getCourse(courseId).data.teacherId == userId;
    }

    function isTeacherOfAssignment(userId, assignmentId) {
        let courseId = getAssignment(assignmentId).data.courseId;
        return isTeacher(userId) && getCourse(courseId).data.teacherId == userId;
    }

    function isStudentOfAssignment(userId, assignmentId) {
        let courseId = getAssignment(assignmentId).data.courseId;
        return getCourse(courseId).data.classIds.hasAny([userId]);
    }
  }
}