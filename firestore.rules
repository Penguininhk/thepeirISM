/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a hybrid security model, combining role-based access for administrative functions with user-ownership for personal data and course-specific access.
 *
 * Data Structure:
 * - /announcements/{announcementId}: Public announcements, accessible to all.
 * - /classes/{classId}: Class details, accessible to enrolled students and teachers.
 * - /classes/{classId}/announcements/{announcementId}: Class-specific announcements, accessible to enrolled students and teachers.
 * - /courses/{courseId}: Course details, manageable by the course teacher.
 * - /courses/{courseId}/assignments/{assignmentId}: Assignments for a course, manageable by the course teacher.
 * - /assignments/{assignmentId}/submissions/{submissionId}: Submissions for an assignment, created by students.
 * - /users/{userId}: User profiles, only accessible to the user themselves.
 * - /users/{userId}/courseSelections/{courseSelectionId}: Course selections, only accessible to the user themselves.
 * - /roles_teacher/{userId}: Indicates a user is a teacher.
 * - /roles_admin/{userId}: Indicates a user is an admin.
 *
 * Key Security Decisions:
 * - Public read access for general announcements.
 * - Course and class data access is restricted to associated teachers and students.
 * - User profiles and course selections are strictly user-owned.
 * - Admin and teacher roles are determined by the existence of documents in specific collections.
 *
 * Denormalization for Authorization:
 * - Classes include denormalized studentIds to allow fast checks for student enrollment.
 * - Announcements include denormalized classIds to allow independent authorization checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to school-wide announcements, and restricts write access to authorized users.
     * @path /announcements/{announcementId}
     * @allow (get, list) - Any user can read announcements.
     * @allow (create) - Only users who are in roles_teacher or roles_admin can create an announcement, and the authorId must match their own userId.
     * @allow (update, delete) - Only the author (teacher or admin) of the announcement can update or delete it.
     * @deny (create) - A user who is not a teacher or admin attempts to create an announcement.
     * @deny (update, delete) - A user who is not the author of the announcement attempts to update or delete it.
     * @principle Allows public reads, enforces teacher/admin-only writes and enforces document ownership for writes.
     */
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow create: if isSignedIn() && (isTeacher(request.auth.uid) || isAdmin(request.auth.uid)) && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (isTeacher(request.auth.uid) || isAdmin(request.auth.uid)) && isExistingOwner(resource.data.authorId);
    }

    /**
     * @description Manages access to class information. Only enrolled students and teachers can read class details.
     * @path /classes/{classId}
     * @allow (get, list) - Enrolled students and teachers can read class details.
     * @allow (create) - No one can create classes via the client (should be handled server-side).
     * @allow (update, delete) - No one can update or delete classes via the client (should be handled server-side).
     * @deny (get, list) - A user who is not a student or teacher attempts to read class details.
     * @deny (create, update, delete) - Any client-side attempt to create, update, or delete class details.
     * @principle Restricts access to class data to authorized users and prevents client-side modifications.
     */
    match /classes/{classId} {
      allow get, list: if isSignedIn() && (isEnrolledStudent(resource.data.studentIds) || isTeacherOfClass(request.auth.uid, resource.data.id));
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages announcements specific to a class. Only enrolled students and teachers can read, and only teachers can create.
     * @path /classes/{classId}/announcements/{announcementId}
     * @allow (get, list) - Enrolled students and teachers can read class announcements.
     * @allow (create) - Only teachers of the class can create class announcements.
     * @allow (update, delete) - Only the author (teacher) of the announcement can update or delete it.
     * @deny (create) - A user who is not a teacher attempts to create a class announcement.
     * @deny (update, delete) - A user who is not the author of the class announcement attempts to update or delete it.
     * @principle Enforces role-based access for class announcements.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get, list: if isSignedIn() && (isEnrolledStudent(get(/databases/$(database)/documents/classes/$(classId)).data.studentIds) || isTeacherOfClass(request.auth.uid, classId));
      allow create: if isSignedIn() && isTeacherOfClass(request.auth.uid, classId) && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && isTeacher(resource.data.authorId) && isExistingOwner(resource.data.authorId);
    }

    /**
     * @description Manages access to course information.
     * @path /courses/{courseId}
     * @allow (get, list) - Any user can read course details.
     * @allow (create) - No one can create courses via the client (should be handled server-side).
     * @allow (update, delete) - Only the teacher of the course can update or delete course details.
     * @deny (update, delete) - A user who is not the teacher of the course attempts to update or delete course details.
     * @principle Enforces teacher-only access for course management.
     */
    match /courses/{courseId} {
      allow get, list: if true;
      allow create: if false;
      allow update, delete: if isSignedIn() && isTeacherOfCourse(request.auth.uid, resource.data.teacherId) && resource != null;
    }

    /**
     * @description Manages assignments for a specific course.
     * @path /courses/{courseId}/assignments/{assignmentId}
     * @allow (get, list) - Any user can read assignments within a course.
     * @allow (create) - Only the teacher of the course can create assignments.
     * @allow (update, delete) - Only the teacher of the course can update or delete assignments.
     * @deny (create) - A user who is not the teacher of the course attempts to create an assignment.
     * @deny (update, delete) - A user who is not the teacher of the course attempts to update or delete an assignment.
     * @principle Enforces teacher-only access for assignment management within courses.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isTeacherOfCourse(request.auth.uid, get(/databases/$(database)/documents/courses/$(courseId)).data.teacherId);
      allow update, delete: if isSignedIn() && isTeacherOfCourse(request.auth.uid, get(/databases/$(database)/documents/courses/$(courseId)).data.teacherId) && resource != null;
    }

    /**
     * @description Manages student submissions for an assignment.
     * @path /assignments/{assignmentId}/submissions/{submissionId}
     * @allow (get) - Any user can get submission details.
     * @allow (list) - Any user can list submission details.
     * @allow (create) - Only the student associated with the submission can create it.
     * @allow (update, delete) - Only the teacher associated with the assignment can update or delete submissions.
     * @deny (create) - A user who is not the associated student attempts to create a submission.
     * @deny (update, delete) - A user who is not the teacher associated with the assignment attempts to update or delete the submission.
     * @principle Enforces student-ownership for creation and teacher-only access for modifications.
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isSignedIn() && isTeacherOfCourse(request.auth.uid, get(/databases/$(database)/documents/assignments/$(assignmentId)).data.courseId) && resource != null;
    }

    /**
     * @description Manages user profile information.
     * @path /users/{userId}
     * @allow (get) - Any user can get user details.
     * @allow (list) - Any user can list user details.
     * @allow (create) - Allows a user to create their own profile.
     * @allow (update, delete) - Only the user themselves can update or delete their profile.
     * @deny (create) - A user attempts to create a profile with an ID that doesn't match their own.
     * @deny (update, delete) - A user attempts to update or delete a profile that doesn't belong to them.
     * @principle Enforces user-ownership for profile management.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.id == request.auth.uid;
      allow update, delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

    /**
     * @description Manages course selections made by students.
     * @path /users/{userId}/courseSelections/{courseSelectionId}
     * @allow (get, list) - Only the user themselves can read their course selections.
     * @allow (create) - Only the user themselves can create course selections.
     * @allow (update, delete) - Only the user themselves can update or delete their course selections.
     * @deny (create) - A user attempts to create a course selection under another user's ID.
     * @deny (update, delete) - A user attempts to update or delete a course selection that doesn't belong to them.
     * @principle Enforces user-ownership for course selection management.
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get, list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

    /**
     * @description Indicates a user is a teacher. The document's existence confers the 'teacher' role.
     * @path /roles_teacher/{userId}
     * @allow (get) - Any user can get teacher roles details.
     * @allow (list) - Any user can list teacher roles details.
     * @allow (create) - No client side creation allowed.
     * @allow (update) - No client side updates allowed.
     * @allow (delete) - No client side deletions allowed.
     * @principle Roles are managed server side.
     */
    match /roles_teacher/{userId} {
        allow get, list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Indicates a user is an administrator. The document's existence confers the 'admin' role.
     * @path /roles_admin/{userId}
     * @allow (get) - Any user can get admin roles details.
     * @allow (list) - Any user can list admin roles details.
     * @allow (create) - No client side creation allowed.
     * @allow (update) - No client side updates allowed.
     * @allow (delete) - No client side deletions allowed.
     * @principle Roles are managed server side.
     */
    match /roles_admin/{userId} {
        allow get, list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    function isTeacher(userId) {
        return exists(/databases/$(database)/documents/roles_teacher/$(userId));
    }

    function isAdmin(userId) {
        return exists(/databases/$(database)/documents/roles_admin/$(userId));
    }

    function isEnrolledStudent(studentIds) {
        return studentIds.hasAny([request.auth.uid]);
    }

    function isTeacherOfCourse(userId, courseId) {
        return get(/databases/$(database)/documents/courses/$(courseId)).data.teacherId == userId;
    }

      function isTeacherOfClass(userId, classId) {
        return exists(/databases/$(database)/documents/roles_teacher/$(userId)) && get(/databases/$(database)/documents/classes/$(classId)).data.courseId != null;
      }
  }
}