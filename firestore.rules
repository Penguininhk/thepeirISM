/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based and ownership-based access control model.
 *  - Admins can manage all data.
 *  - Teachers can manage data related to their courses and classes.
 *  - Students can only access their own data or data explicitly shared with them.
 *  - Unauthenticated access is forbidden.
 *
 * Data Structure:
 * - /actionLogs/{actionLogId}: Logs of administrative actions, only accessible to admins.
 * - /announcements/{announcementId}: School-wide announcements, publicly readable, but only admins/teachers can write.
 * - /classes/{classId}: Class information, readable by enrolled students and teachers.
 * - /classes/{classId}/announcements/{announcementId}: Announcements specific to a class.
 * - /courses/{courseId}: Course information, readable by anyone, but only the teacher can modify.
 * - /courses/{courseId}/assignments/{assignmentId}: Assignments for a specific course.
 * - /assignments/{assignmentId}/submissions/{submissionId}: Student submissions for assignments.
 * - /users/{userId}: User profiles, only accessible to the user themselves and admins.
 * - /users/{userId}/courseSelections/{courseSelectionId}: Course selections made by a student, only accessible to the student and admins.
 * - /roles_teacher/{userId}: Indicates if a user is a teacher.
 * - /roles_admin/{userId}: Indicates if a user is an admin.
 *
 * Key Security Decisions:
 * - Public listing of users is disallowed.
 * - Strict ownership is enforced for user-specific data.
 * - Roles are determined by the existence of documents in `/roles_teacher` and `/roles_admin`.
 *
 * Denormalization for Authorization:
 * - The rules leverage the explicit `/roles_teacher/{userId}` and `/roles_admin/{userId}` document structure to identify roles, avoiding complex queries.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isTeacher() {
      return exists(/databases/$(database)/documents/roles_teacher/$(request.auth.uid));
    }
    
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
    
    /**
     * @description: Grants admins full access to action logs.
     * @path: /actionLogs/{actionLogId}
     * @allow: (create) - Admin user creates an action log.
     * @deny: (create) - Non-admin user attempts to create an action log.
     * @principle: Enforces admin-only access for sensitive action logs.
     */
    match /actionLogs/{actionLogId} {
      allow get: if isAdmin();
      allow list: if false; // No listing.

      allow create: if isAdmin();
      allow update: if false; // No updates after creation.
      allow delete: if false; // No deletion.
    }

    /**
     * @description: Allows anyone to read school-wide announcements, but only admins/teachers can create or modify them.
     * @path: /announcements/{announcementId}
     * @allow: (get) - Any user can read an announcement.
     * @allow: (create) - Admin/Teacher user creates an announcement.
     * @deny: (create) - Non-admin/teacher user attempts to create an announcement.
     * @principle: Allows public read access for general announcements while restricting write access.
     */
    match /announcements/{announcementId} {
      allow get, list: if true;

      allow create: if (isAdmin() || isTeacher());
      allow update: if (isAdmin() || isTeacher());
      allow delete: if isAdmin();
    }

    /**
     * @description: Restricts access to class information to enrolled students and teachers, or admins.
     * @path: /classes/{classId}
     * @allow: (get) - Enrolled student or teacher, or admin, can read class info.
     * @allow: (create) - Admin user creates a class.
     * @deny: (get) - Non-enrolled student attempts to read class info.
     * @principle: Limits class information visibility to relevant parties.
     */
    match /classes/{classId} {
      allow get, list: if (isAdmin() || isTeacher());

      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description: Class-specific announcements, accessible to students in the class, teachers, and admins.
     * @path: /classes/{classId}/announcements/{announcementId}
     * @allow: (get) - Student in class, teacher, or admin can read announcement.
     * @allow: (create) - Teacher or admin can create an announcement for the class.
     * @deny: (get) - Student not in the class attempts to read announcement.
     * @principle: Ensures only relevant parties can access class-specific announcements.
     */
    match /classes/{classId}/announcements/{announcementId} {
      allow get, list: if (isAdmin() || isTeacher());

      allow create: if (isAdmin() || isTeacher());
      allow update: if (isAdmin() || isTeacher());
      allow delete: if isAdmin();
    }

    /**
     * @description: Allows anyone to read course information, but only the teacher can modify it.
     * @path: /courses/{courseId}
     * @allow: (get) - Any user can read course info.
     * @allow: (update) - Teacher updates course info.
     * @deny: (update) - Non-teacher attempts to update course info.
     * @principle: Allows public read access while restricting write access to the teacher.
     */
    match /courses/{courseId} {
      allow get, list: if true;

      allow create: if (isAdmin() || isTeacher());
      allow update: if (isAdmin() || isTeacher());
      allow delete: if isAdmin();
    }

    /**
     * @description: Assignments for a specific course, accessible to the teacher and students in the course.
     * @path: /courses/{courseId}/assignments/{assignmentId}
     * @allow: (get) - Teacher or student in the course can read assignment.
     * @allow: (create) - Teacher creates an assignment for the course.
     * @deny: (get) - Student not in the course attempts to read assignment.
     * @principle: Limits assignment visibility to relevant course participants.
     */
    match /courses/{courseId}/assignments/{assignmentId} {
      allow get, list: if (isAdmin() || isTeacher());

      allow create: if (isAdmin() || isTeacher());
      allow update: if (isAdmin() || isTeacher());
      allow delete: if isAdmin();
    }

    /**
     * @description: Student submissions for assignments, accessible to the student, the teacher, and admins.
     * @path: /assignments/{assignmentId}/submissions/{submissionId}
     * @allow: (get) - Student or teacher can read a submission.
     * @allow: (create) - Student creates a submission for the assignment.
     * @deny: (get) - Non-student attempts to read another student's submission.
     * @principle: Ensures only relevant parties can access student submissions.
     */
    match /assignments/{assignmentId}/submissions/{submissionId} {
      allow get: if (isAdmin() || isTeacher());
      allow list: if false;

      allow create: if isSignedIn();
      allow update: if (isAdmin() || isTeacher());
      allow delete: if isAdmin();
    }

    /**
     * @description: User profiles, only accessible to the user themselves and admins.
     * @path: /users/{userId}
     * @allow: (get) - User can read their own profile.
     * @allow: (create) - User can create their own profile (self-registration).
     * @deny: (get) - User attempts to read another user's profile.
     * @principle: Enforces user ownership and restricts unauthorized access to user data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false; // Disallow listing of all users

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    /**
     * @description: Course selections made by a student, only accessible to the student and admins.
     * @path: /users/{userId}/courseSelections/{courseSelectionId}
     * @allow: (get) - Student can read their own course selections.
     * @allow: (create) - Student can create course selections.
     * @deny: (get) - User attempts to read another user's course selections.
     * @principle: Enforces user ownership and restricts unauthorized access to course selection data.
     */
    match /users/{userId}/courseSelections/{courseSelectionId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    /**
     * @description: Indicates a user is a teacher. Only admins can create/delete these documents.
     * @path: /roles_teacher/{userId}
     */
    match /roles_teacher/{userId} {
      allow get: if isAdmin() || isTeacher();
      allow list: if false;

      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    /**
     * @description: Indicates a user is an admin. Only admins can create/delete these documents.
     * @path: /roles_admin/{userId}
     */
    match /roles_admin/{userId} {
      allow get: if isAdmin();
      allow list: if false;

      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}